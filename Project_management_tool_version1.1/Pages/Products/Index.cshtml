@page
@model Project_management_tool_version1._1.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Products";
    var canEdit = User.IsInRole("Admin") || User.IsInRole("ProjectManager") || User.IsInRole("Developer") || User.IsInRole("QA");
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Products</h2>
    @if (canEdit)
    {
        <a asp-page="/Products/Create" class="btn btn-primary">Create Product</a>
    }
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-3">
        <input name="Search" value="@Model.Search" class="form-control" placeholder="Search name, version, project" />
    </div>
    <div class="col-md-2">
        <select name="Status" class="form-select">
            <option value="">All statuses</option>
            @foreach (var status in Model.AvailableStatuses)
            {
                <option value="@status" selected="@(Model.Status == status)">@status</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <select name="Project" class="form-select">
            <option value="">All projects</option>
            @foreach (var project in Model.AvailableProjects)
            {
                <option value="@project" selected="@(Model.Project == project)">@project</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <select name="SortBy" class="form-select">
            <option value="Name" selected="@(Model.SortBy == "Name")">Sort: Name</option>
            <option value="Version" selected="@(Model.SortBy == "Version")">Sort: Version</option>
            <option value="Project" selected="@(Model.SortBy == "Project")">Sort: Project</option>
            <option value="Status" selected="@(Model.SortBy == "Status")">Sort: Status</option>
            <option value="PlannedRelease" selected="@(Model.SortBy == "PlannedRelease")">Sort: Release</option>
        </select>
    </div>
    <div class="col-md-1">
        <select name="SortDirection" class="form-select">
            <option value="asc" selected="@(Model.SortDirection == "asc")">Asc</option>
            <option value="desc" selected="@(Model.SortDirection == "desc")">Desc</option>
        </select>
    </div>
    <div class="col-md-1">
        <select name="PageSize" class="form-select">
            @foreach (var size in Model.PageSizeOptions)
            {
                <option value="@size" selected="@(Model.PageSize == size)">@size</option>
            }
        </select>
    </div>
    <div class="col-md-1 d-flex gap-2">
        <button type="submit" class="btn btn-outline-primary w-100">Go</button>
        <a asp-page="/Products/Index" class="btn btn-outline-secondary">Reset</a>
    </div>
</form>

<div class="small text-muted mb-2">Showing @Model.Products.Count of @Model.TotalCount products</div>

@if (!Model.Products.Any())
{
    <div class="alert alert-info">No products found.</div>
}
else
{
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Name</th>
                <th>Version</th>
                <th>Project</th>
                <th>Status</th>
                <th>Planned Release</th>
                @if (canEdit)
                {
                    <th></th>
                }
            </tr>
        </thead>
        <tbody>
        @foreach (var product in Model.Products)
        {
            <tr>
                <td>@product.Name</td>
                <td>@product.VersionName</td>
                <td>@product.Project?.Name</td>
                <td>@product.Status</td>
                <td>@product.PlannedReleaseDate</td>
                @if (canEdit)
                {
                    <td class="text-nowrap">
                        <a asp-page="/Products/Edit" asp-route-id="@product.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        <a asp-page="/Products/Delete" asp-route-id="@product.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                }
            </tr>
        }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Products pagination">
            <ul class="pagination">
                <li class="page-item @(Model.Page <= 1 ? "disabled" : null)">
                    <a class="page-link"
                       asp-page="/Products/Index"
                       asp-route-Search="@Model.Search"
                       asp-route-Status="@Model.Status"
                       asp-route-Project="@Model.Project"
                       asp-route-SortBy="@Model.SortBy"
                       asp-route-SortDirection="@Model.SortDirection"
                       asp-route-PageSize="@Model.PageSize"
                       asp-route-Page="@(Model.Page - 1)">Previous</a>
                </li>
                @for (var i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Page ? "active" : null)">
                        <a class="page-link"
                           asp-page="/Products/Index"
                           asp-route-Search="@Model.Search"
                           asp-route-Status="@Model.Status"
                           asp-route-Project="@Model.Project"
                           asp-route-SortBy="@Model.SortBy"
                           asp-route-SortDirection="@Model.SortDirection"
                           asp-route-PageSize="@Model.PageSize"
                           asp-route-Page="@i">@i</a>
                    </li>
                }
                <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : null)">
                    <a class="page-link"
                       asp-page="/Products/Index"
                       asp-route-Search="@Model.Search"
                       asp-route-Status="@Model.Status"
                       asp-route-Project="@Model.Project"
                       asp-route-SortBy="@Model.SortBy"
                       asp-route-SortDirection="@Model.SortDirection"
                       asp-route-PageSize="@Model.PageSize"
                       asp-route-Page="@(Model.Page + 1)">Next</a>
                </li>
            </ul>
        </nav>
    }
}
