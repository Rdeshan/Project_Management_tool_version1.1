@page "{id:guid}"
@model Project_management_tool_version1._1.Pages.Products.DeleteModel
@{
    ViewData["Title"] = "Delete Product";
}

<h2 class="mb-3">Delete Product</h2>

@if (Model.Product is null)
{
    <div class="alert alert-warning">Product not found.</div>
}
else
{
    <div class="alert alert-warning">
        Are you sure you want to delete <strong>@Model.Product.Name (@Model.Product.VersionName)</strong>?
    </div>

    <dl class="row">
        <dt class="col-sm-3">Project</dt>
        <dd class="col-sm-9">@Model.Product.Project?.Name</dd>

        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">@Model.Product.Status</dd>
    </dl>

    <form method="post">
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-page="/Products/Index" class="btn btn-outline-secondary">Cancel</a>
    </form>
}
