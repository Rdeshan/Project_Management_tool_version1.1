@page
@model Project_management_tool_version1._1.Pages.Auth.LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">User Login</h2>

                @if (Model.IsAuthenticated)
                {
                    <div class="alert alert-success" role="alert">
                        @Model.AuthenticatedMessage
                    </div>
                }

                @if (Model.IsDevelopment && Model.QuickRoles.Count > 0)
                {
                    <div class="mb-3">
                        <div class="small text-muted mb-2">Development quick login</div>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var roleName in Model.QuickRoles)
                            {
                                <form method="post" asp-page-handler="QuickLogin" asp-route-roleName="@roleName" asp-route-returnUrl="@Model.ReturnUrl">
                                    <button type="submit" class="btn btn-outline-secondary btn-sm">@roleName</button>
                                </form>
                            }
                        </div>
                    </div>
                }

                <form method="post">
                    <input type="hidden" asp-for="ReturnUrl" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label"></label>
                        <input asp-for="Input.Email" class="form-control" autocomplete="username" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label"></label>
                        <input asp-for="Input.Password" class="form-control" autocomplete="current-password" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Login</button>
                </form>

                <div class="mt-3 text-center">
                    <a asp-page="/Auth/ForgotPassword">Forgot your password?</a>
                </div>

                @if (Model.ExternalProviders.Count > 0)
                {
                    <div class="my-3"><hr /></div>
                    <div class="small text-muted mb-2">Or sign in with</div>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var provider in Model.ExternalProviders)
                        {
                            <form method="post" asp-page-handler="ExternalLogin" asp-route-provider="@provider" asp-route-returnUrl="@Model.ReturnUrl">
                                <button type="submit" class="btn btn-outline-primary btn-sm">@provider</button>
                            </form>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
