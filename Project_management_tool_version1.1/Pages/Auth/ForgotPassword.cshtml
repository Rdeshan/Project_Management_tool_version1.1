@page
@model Project_management_tool_version1._1.Pages.Auth.ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Forgot Password</h2>

                @if (Model.IsSubmitted)
                {
                    <div class="alert alert-info" role="alert">
                        If an active account exists for that email, a password reset link has been sent.
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.DevResetLink))
                    {
                        <div class="alert alert-secondary" role="alert">
                            Development reset link: <a href="@Model.DevResetLink">@Model.DevResetLink</a>
                        </div>
                    }
                }
                else
                {
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Input.Email" class="form-label"></label>
                            <input asp-for="Input.Email" class="form-control" autocomplete="email" />
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Send reset link</button>
                    </form>
                }

                <div class="mt-3 text-center">
                    <a asp-page="/Auth/Login">Back to login</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
