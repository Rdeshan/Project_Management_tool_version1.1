@page "{id:guid}"
@model Project_management_tool_version1._1.Pages.Tickets.EditModel
@{
    ViewData["Title"] = "Edit Ticket";
}

<h2 class="mb-3">Edit Ticket</h2>

<div class="row">
    <div class="col-md-10 col-lg-8">
        <form method="post">
            <input asp-for="Input.Id" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="Input.TicketNumber" class="form-label"></label>
                    <input asp-for="Input.TicketNumber" class="form-control" />
                    <span asp-validation-for="Input.TicketNumber" class="text-danger"></span>
                </div>
                <div class="col-md-8 mb-3">
                    <label asp-for="Input.Title" class="form-label"></label>
                    <input asp-for="Input.Title" class="form-control" />
                    <span asp-validation-for="Input.Title" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Description" class="form-label"></label>
                <textarea asp-for="Input.Description" rows="4" class="form-control"></textarea>
                <span asp-validation-for="Input.Description" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="Input.Category" class="form-label"></label>
                    <select asp-for="Input.Category" asp-items="Model.Categories" class="form-select"></select>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Input.Priority" class="form-label"></label>
                    <select asp-for="Input.Priority" asp-items="Model.Priorities" class="form-select"></select>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Input.Status" class="form-label"></label>
                    <select asp-for="Input.Status" asp-items="Model.Statuses" class="form-select"></select>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="Input.ProjectId" class="form-label">Project</label>
                    <select asp-for="Input.ProjectId" asp-items="Model.Projects" class="form-select">
                        <option value="">-- select project --</option>
                    </select>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Input.ProductId" class="form-label">Product</label>
                    <select asp-for="Input.ProductId" asp-items="Model.Products" class="form-select">
                        <option value="">-- optional --</option>
                    </select>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Input.SubProjectId" class="form-label">SubProject</label>
                    <select asp-for="Input.SubProjectId" asp-items="Model.SubProjects" class="form-select">
                        <option value="">-- optional --</option>
                    </select>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Input.ExpectedDueDate" class="form-label"></label>
                <input asp-for="Input.ExpectedDueDate" class="form-control" />
                <span asp-validation-for="Input.ExpectedDueDate" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save</button>
                <a asp-page="/Tickets/Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
