@page "{id:guid}"
@model Project_management_tool_version1._1.Pages.Tickets.DeleteModel
@{
    ViewData["Title"] = "Delete Ticket";
}

<h2 class="mb-3">Delete Ticket</h2>

@if (Model.Ticket is null)
{
    <div class="alert alert-warning">Ticket not found.</div>
}
else
{
    <div class="alert alert-warning">
        Are you sure you want to delete <strong>@Model.Ticket.TicketNumber - @Model.Ticket.Title</strong>?
    </div>

    <dl class="row">
        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">@Model.Ticket.Status</dd>

        <dt class="col-sm-3">Priority</dt>
        <dd class="col-sm-9">@Model.Ticket.Priority</dd>
    </dl>

    <form method="post">
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-page="/Tickets/Index" class="btn btn-outline-secondary">Cancel</a>
    </form>
}
