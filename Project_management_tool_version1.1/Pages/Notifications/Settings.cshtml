@page
@model Project_management_tool_version1._1.Pages.Notifications.SettingsModel
@{
    ViewData["Title"] = "Notification Settings";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Email Notification Settings</h2>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-success">@Model.StatusMessage</div>
}

<form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="table-responsive">
        <table class="table table-striped table-bordered align-middle">
            <thead>
                <tr>
                    <th>Event</th>
                    <th>Recipient Type</th>
                    <th>In-App</th>
                    <th>Email</th>
                    <th>Delivery</th>
                    <th>Escalation Delay (Days)</th>
                    <th>Repeat Interval (Days)</th>
                    <th>Subject Template</th>
                </tr>
            </thead>
            <tbody>
            @for (var i = 0; i < Model.Events.Count; i++)
            {
                <tr>
                    <td>
                        <input asp-for="Events[i].EventName" type="hidden" />
                        <strong>@Model.Events[i].EventName</strong>
                    </td>
                    <td>
                        <select asp-for="Events[i].RecipientType" class="form-select form-select-sm">
                            @foreach (var recipientType in Model.RecipientTypes)
                            {
                                <option value="@recipientType">@recipientType</option>
                            }
                        </select>
                    </td>
                    <td class="text-center">
                        <input asp-for="Events[i].InAppEnabled" class="form-check-input" />
                    </td>
                    <td class="text-center">
                        <input asp-for="Events[i].EmailEnabled" class="form-check-input" />
                    </td>
                    <td>
                        <select asp-for="Events[i].DeliveryMode" class="form-select form-select-sm"
                                asp-items="Html.GetEnumSelectList<Project_management_tool_version1._1.Pages.Notifications.SettingsModel.DeliveryMode>()">
                        </select>
                    </td>
                    <td>
                        <input asp-for="Events[i].EscalationDelayBusinessDays" class="form-control form-control-sm" />
                    </td>
                    <td>
                        <input asp-for="Events[i].RepeatIntervalBusinessDays" class="form-control form-control-sm" />
                    </td>
                    <td>
                        <input asp-for="Events[i].SubjectTemplate" class="form-control form-control-sm" />
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    <div class="small text-muted mb-3">
        Supported variables: <code>{ticket_id}</code>, <code>{ticket_title}</code>, <code>{project_name}</code>, <code>{status}</code>, <code>{days_overdue}</code>, <code>{due_date}</code>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Save Settings</button>
        <a asp-page="/Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
