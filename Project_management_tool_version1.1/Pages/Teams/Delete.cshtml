@page "{id:guid}"
@model Project_management_tool_version1._1.Pages.Teams.DeleteModel
@{
    ViewData["Title"] = "Delete Team";
}

<h2 class="mb-3">Delete Team</h2>

@if (Model.Team is null)
{
    <div class="alert alert-warning">Team not found.</div>
}
else
{
    <div class="alert alert-warning">
        Are you sure you want to delete <strong>@Model.Team.Name</strong>?
    </div>

    <dl class="row">
        <dt class="col-sm-3">Description</dt>
        <dd class="col-sm-9">@Model.Team.Description</dd>
    </dl>

    <form method="post">
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-page="/Teams/Index" class="btn btn-outline-secondary">Cancel</a>
    </form>
}
