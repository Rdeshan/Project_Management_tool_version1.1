@page
@model Project_management_tool_version1._1.Pages.Projects.IndexModel
@{
    ViewData["Title"] = "Projects";
    var canEdit = User.IsInRole("Admin") || User.IsInRole("ProjectManager") || User.IsInRole("Developer") || User.IsInRole("QA");
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Projects</h2>
    @if (canEdit)
    {
        <a asp-page="/Projects/Create" class="btn btn-primary">Create Project</a>
    }
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-3">
        <input name="Search" value="@Model.Search" class="form-control" placeholder="Search code, name, client" />
    </div>
    <div class="col-md-2">
        <select name="Status" class="form-select">
            <option value="">All statuses</option>
            @foreach (var status in Model.AvailableStatuses)
            {
                <option value="@status" selected="@(Model.Status == status)">@status</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <select name="SortBy" class="form-select">
            <option value="Name" selected="@(Model.SortBy == "Name")">Sort: Name</option>
            <option value="Code" selected="@(Model.SortBy == "Code")">Sort: Code</option>
            <option value="Client" selected="@(Model.SortBy == "Client")">Sort: Client</option>
            <option value="Status" selected="@(Model.SortBy == "Status")">Sort: Status</option>
            <option value="StartDate" selected="@(Model.SortBy == "StartDate")">Sort: Start Date</option>
        </select>
    </div>
    <div class="col-md-2">
        <select name="SortDirection" class="form-select">
            <option value="asc" selected="@(Model.SortDirection == "asc")">Ascending</option>
            <option value="desc" selected="@(Model.SortDirection == "desc")">Descending</option>
        </select>
    </div>
    <div class="col-md-2">
        <select name="PageSize" class="form-select">
            @foreach (var size in Model.PageSizeOptions)
            {
                <option value="@size" selected="@(Model.PageSize == size)">@size</option>
            }
        </select>
    </div>
    <div class="col-md-1 d-flex gap-2">
        <button type="submit" class="btn btn-outline-primary w-100">Go</button>
        <a asp-page="/Projects/Index" class="btn btn-outline-secondary">Reset</a>
    </div>
</form>

<div class="small text-muted mb-2">Showing @Model.Projects.Count of @Model.TotalCount projects</div>

@if (!Model.Projects.Any())
{
    <div class="alert alert-info">No projects found.</div>
}
else
{
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Code</th>
                <th>Name</th>
                <th>Client</th>
                <th>Status</th>
                <th>Start Date</th>
                @if (canEdit)
                {
                    <th></th>
                }
            </tr>
        </thead>
        <tbody>
        @foreach (var project in Model.Projects)
        {
            <tr>
                <td>@project.Code</td>
                <td>@project.Name</td>
                <td>@project.ClientName</td>
                <td>@project.Status</td>
                <td>@project.StartDate</td>
                @if (canEdit)
                {
                    <td class="text-nowrap">
                        <a asp-page="/Projects/Edit" asp-route-id="@project.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        <a asp-page="/Projects/Delete" asp-route-id="@project.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                }
            </tr>
        }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Projects pagination">
            <ul class="pagination">
                <li class="page-item @(Model.Page <= 1 ? "disabled" : null)">
                    <a class="page-link"
                       asp-page="/Projects/Index"
                       asp-route-Search="@Model.Search"
                       asp-route-Status="@Model.Status"
                       asp-route-SortBy="@Model.SortBy"
                       asp-route-SortDirection="@Model.SortDirection"
                       asp-route-PageSize="@Model.PageSize"
                       asp-route-Page="@(Model.Page - 1)">Previous</a>
                </li>
                @for (var i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Page ? "active" : null)">
                        <a class="page-link"
                           asp-page="/Projects/Index"
                           asp-route-Search="@Model.Search"
                           asp-route-Status="@Model.Status"
                           asp-route-SortBy="@Model.SortBy"
                           asp-route-SortDirection="@Model.SortDirection"
                           asp-route-PageSize="@Model.PageSize"
                           asp-route-Page="@i">@i</a>
                    </li>
                }
                <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : null)">
                    <a class="page-link"
                       asp-page="/Projects/Index"
                       asp-route-Search="@Model.Search"
                       asp-route-Status="@Model.Status"
                       asp-route-SortBy="@Model.SortBy"
                       asp-route-SortDirection="@Model.SortDirection"
                       asp-route-PageSize="@Model.PageSize"
                       asp-route-Page="@(Model.Page + 1)">Next</a>
                </li>
            </ul>
        </nav>
    }
}
