@page "{id:guid}"
@model Project_management_tool_version1._1.Pages.SubProjects.DeleteModel
@{
    ViewData["Title"] = "Delete SubProject";
}

<h2 class="mb-3">Delete SubProject</h2>

@if (Model.SubProject is null)
{
    <div class="alert alert-warning">SubProject not found.</div>
}
else
{
    <div class="alert alert-warning">
        Are you sure you want to delete <strong>@Model.SubProject.Name</strong>?
    </div>

    <dl class="row">
        <dt class="col-sm-3">Module Owner</dt>
        <dd class="col-sm-9">@Model.SubProject.ModuleOwner</dd>

        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">@Model.SubProject.Status</dd>
    </dl>

    <form method="post">
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-page="/SubProjects/Index" class="btn btn-outline-secondary">Cancel</a>
    </form>
}
