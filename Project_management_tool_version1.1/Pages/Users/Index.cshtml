@page
@model Project_management_tool_version1._1.Pages.Users.IndexModel
@{
    ViewData["Title"] = "Users";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Users</h2>
    <a asp-page="/Users/Create" class="btn btn-primary">Create User</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input name="Search" value="@Model.Search" class="form-control" placeholder="Search name or email" />
    </div>
    <div class="col-md-2">
        <select name="Role" class="form-select">
            <option value="">All roles</option>
            @foreach (var role in Model.AvailableRoles)
            {
                <option value="@role" selected="@(Model.Role == role)">@role</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <select name="Team" class="form-select">
            <option value="">All teams</option>
            @foreach (var team in Model.AvailableTeams)
            {
                <option value="@team" selected="@(Model.Team == team)">@team</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <select name="SortBy" class="form-select">
            <option value="Name" selected="@(Model.SortBy == "Name")">Sort: Name</option>
            <option value="Email" selected="@(Model.SortBy == "Email")">Sort: Email</option>
            <option value="Status" selected="@(Model.SortBy == "Status")">Sort: Status</option>
        </select>
    </div>
    <div class="col-md-2">
        <select name="SortDirection" class="form-select">
            <option value="asc" selected="@(Model.SortDirection == "asc")">Ascending</option>
            <option value="desc" selected="@(Model.SortDirection == "desc")">Descending</option>
        </select>
    </div>
    <div class="col-md-2 d-flex gap-2">
        <select name="PageSize" class="form-select">
            @foreach (var size in Model.PageSizeOptions)
            {
                <option value="@size" selected="@(Model.PageSize == size)">@size</option>
            }
        </select>
        <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
        <a asp-page="/Users/Index" class="btn btn-outline-secondary">Reset</a>
    </div>
</form>

<div class="row g-2 mb-3">
    <div class="col-md-4">
        <div class="card border-success text-center">
            <div class="card-body py-2">
                <div class="small text-muted">Active</div>
                <div class="h5 mb-0">@Model.ActiveUserCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-warning text-center">
            <div class="card-body py-2">
                <div class="small text-muted">Inactive</div>
                <div class="h5 mb-0">@Model.InactiveUserCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-danger text-center">
            <div class="card-body py-2">
                <div class="small text-muted">Locked</div>
                <div class="h5 mb-0">@Model.LockedUserCount</div>
            </div>
        </div>
    </div>
</div>

<div class="small text-muted mb-2">Showing @Model.Users.Count of @Model.TotalCount users</div>

@if (!Model.Users.Any())
{
    <div class="alert alert-info">No users found.</div>
}
else
{
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Roles</th>
                <th>Teams</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var user in Model.Users)
        {
            <tr>
                <td>@user.FirstName @user.LastName</td>
                <td>@user.Email</td>
                <td>
                    @{
                        var roles = Model.RoleNamesByUserId.TryGetValue(user.Id, out var roleNames)
                            ? roleNames
                            : [];
                    }
                    @(roles.Count > 0 ? string.Join(", ", roles) : "-")
                </td>
                <td>
                    @{
                        var teams = Model.TeamNamesByUserId.TryGetValue(user.Id, out var teamNames)
                            ? teamNames
                            : [];
                    }
                    @(teams.Count > 0 ? string.Join(", ", teams) : "-")
                </td>
                <td>@user.Status</td>
                <td class="text-nowrap">
                    <a asp-page="/Users/Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    <a asp-page="/Users/Delete" asp-route-id="@user.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Users pagination">
            <ul class="pagination">
                <li class="page-item @(Model.Page <= 1 ? "disabled" : null)">
                    <a class="page-link"
                       asp-page="/Users/Index"
                       asp-route-Search="@Model.Search"
                       asp-route-Role="@Model.Role"
                       asp-route-Team="@Model.Team"
                       asp-route-SortBy="@Model.SortBy"
                       asp-route-SortDirection="@Model.SortDirection"
                       asp-route-PageSize="@Model.PageSize"
                       asp-route-Page="@(Model.Page - 1)">Previous</a>
                </li>

                @for (var i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Page ? "active" : null)">
                        <a class="page-link"
                           asp-page="/Users/Index"
                           asp-route-Search="@Model.Search"
                           asp-route-Role="@Model.Role"
                           asp-route-Team="@Model.Team"
                           asp-route-SortBy="@Model.SortBy"
                           asp-route-SortDirection="@Model.SortDirection"
                           asp-route-PageSize="@Model.PageSize"
                           asp-route-Page="@i">@i</a>
                    </li>
                }

                <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : null)">
                    <a class="page-link"
                       asp-page="/Users/Index"
                       asp-route-Search="@Model.Search"
                       asp-route-Role="@Model.Role"
                       asp-route-Team="@Model.Team"
                       asp-route-SortBy="@Model.SortBy"
                       asp-route-SortDirection="@Model.SortDirection"
                       asp-route-PageSize="@Model.PageSize"
                       asp-route-Page="@(Model.Page + 1)">Next</a>
                </li>
            </ul>
        </nav>
    }
}
